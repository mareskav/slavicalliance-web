# Copy to .env.local for local development, or set these variables in Cloudflare.
#
# Next.js apps load env files from their own app directory by default. For local
# monorepo development, apps/results also falls back to this root .env.local.

# Local PostgreSQL example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/slavicalliance?schema=public"

# Neon PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

DATABASE_URL=""

# Canonical site app URL used by apps/results header links.
# Local default in code is http://localhost:3000
SITE_APP_URL=""
NEXT_PUBLIC_SITE_APP_URL=""

# Canonical results app URL used by apps/site header and footer links.
# Local default in code is http://localhost:3001/vysledky
NEXT_PUBLIC_RESULTS_APP_URL=""

# apps/site content is stored in a Cloudflare R2 binding named CONTENT_BUCKET.
# The binding is configured in apps/site/wrangler.jsonc, not in this file.
#
# /admin is intentionally outside the current deploy scope. Only set these when
# enabling the admin Functions routes.
ADMIN_PASSWORD=""
SESSION_SECRET=""

# Web Push / PWA push notifications (VAPID keys)
# Generate once with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY must be the same value.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@slavicalliance.cz"
# Exposed to the browser for PushManager.subscribe()
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# Secret for the /api/push/notify cron endpoint (called by GitHub Actions).
# Generate with: openssl rand -hex 32
CRON_SECRET=""
