# Copy to .env.local for local development, or set these variables in your hosting provider.
#
# Next.js apps load env files from their own app directory by default. For local
# monorepo development, apps/results also falls back to this root .env.local.

# Local PostgreSQL example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/slavicalliance?schema=public"

# Neon PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require"

DATABASE_URL=""

# URL of the standalone results page used by apps/site /vysledky.
# Local default in code is http://localhost:3001/vysledky
RESULTS_APP_URL=""

# Public build-time URL for the static apps/site /vysledky redirect.
# Set this in Cloudflare Pages for apps/site.
NEXT_PUBLIC_RESULTS_APP_URL=""

# Canonical site app URL used by apps/results header links.
# Local default in code is http://localhost:3000
SITE_APP_URL=""
NEXT_PUBLIC_SITE_APP_URL=""

# apps/site admin on Cloudflare Pages Functions.
# Set these in Cloudflare Pages environment variables/secrets, not in public
# NEXT_PUBLIC_* variables.
ADMIN_PASSWORD=""
SESSION_SECRET=""
GITHUB_TOKEN=""
GITHUB_OWNER="mareskav"
GITHUB_REPO="slavicalliance-web"
GITHUB_BRANCH="main"
GITHUB_COMMITTER_NAME="Slavic Alliance Admin"
GITHUB_COMMITTER_EMAIL="admin@example.com"
