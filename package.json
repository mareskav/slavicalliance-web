{
  "name": "slavicalliance",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:site": "npm --workspace apps/site run dev",
    "build:site": "npm --workspace apps/site run build",
    "dev:results": "npm --workspace apps/results run dev",
    "build:results": "npm --workspace apps/results run build",
    "preview:results": "npm --workspace apps/results run preview",
    "deploy:results": "npm --workspace apps/results run deploy",
    "upload:results": "npm --workspace apps/results run upload"
  }
}
