{
  "name": "@slavicalliance-web/results",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:next": "next dev --webpack --hostname localhost --port 3001",
    "build": "next build --webpack",
    "start": "next start --hostname localhost --port 3001",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "predeploy": "node scripts/patch-opennext-windows.mjs",
    "preupload": "node scripts/patch-opennext-windows.mjs",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@repo/ui": "*",
    "lucide-react": "^0.511.0",
    "next": "16.2.6",
    "pg": "^8.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.41",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "wrangler": "4.94.0"
  }
}
